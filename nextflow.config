// Project-level Nextflow configuration (tracked in git).
// This complements (overrides) the nf-core pipeline defaults cached under ~/.nextflow/assets/.
//
// Usage:
//   nextflow run nf-core/cutandrun -r 3.2.2 -profile singularity -c nextflow.config ...

// Keep work directory inside the project by default.
// (Override at runtime with: -work-dir /path/to/scratch/work)
workDir = "${baseDir}/work"

// Prefer writing Nextflow logs outside the repo via NXF_LOG_FILE (you set this in ~/.bashrc).
// You can also override per-run with: -log logs/nextflow/<run>.log

// Sensible defaults for nf-core/cutandrun on a workstation.
params {
  // Work around Trim Galore module issues / avoid trimming unless you explicitly want it.
  // Override on the CLI with --skip_trimming false (or remove this line if you prefer trimming).
  skip_trimming = true

  // Avoid expensive deeptools matrix across all samples unless needed.
  dt_calc_all_matrix = false
}

process {
  // Let nf-core choose resources, but cap the default parallelism a bit.
  // Adjust for your machine or set per-process overrides in a separate config if needed.
  maxForks = 8
}

